# Suri 环境变量
# 权限建议: chmod 600 .env
# 请勿提交到版本控制

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=@shushi_hermesbot
TELEGRAM_CENTRAL_GROUP_ID=@shushi_central_group

# 部门群组
TELEGRAM_DESIGN_GROUP=@shushi_design_group
TELEGRAM_ENGINEERING_GROUP=@shushi_eng_group
TELEGRAM_OPS_GROUP=@shushi_ops_group
TELEGRAM_RESOURCE_GROUP=@shushi_resource_group
TELEGRAM_HR_GROUP=@shushi_hr_group

# 模型 API (按需填写)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 其他服务
SEARCH_API_KEY=
IMAGE_GEN_API_KEY=

# 数据库
DATABASE_URL=sqlite:///state.db

# 日志
LOG_LEVEL=INFO
