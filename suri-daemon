#!/bin/bash
# Suri Agent 守护进程管理器
# 用法: suri-daemon [start|stop|status|restart]

# 获取脚本的真实路径（处理符号链接）
SCRIPT_PATH="$0"
if [ -L "$SCRIPT_PATH" ]; then
    LINK_TARGET="$(readlink "$SCRIPT_PATH")"
    if [[ "$LINK_TARGET" != /* ]]; then
        LINK_TARGET="$(dirname "$SCRIPT_PATH")/$LINK_TARGET"
    fi
    SCRIPT_PATH="$LINK_TARGET"
fi

PROJECT_ROOT="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
export PYTHONPATH="$PROJECT_ROOT/suri-agent:$PYTHONPATH"

cd "$PROJECT_ROOT/suri-agent"
python3 daemon.py "$@"
