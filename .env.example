# suri 环境变量模板
# 复制此文件为 .env 后填写实际值
# 注意：.env 文件由程序运行时自动写入，不应手动修改

# ==================== 模型配置（由首次运行引导或 /model 命令自动写入）====================
# DEFAULT_MODEL=
# DEFAULT_MODEL_API_KEY=
# DEFAULT_MODEL_BASE_URL=
# DEFAULT_MODEL_PROVIDER=

# ==================== 可选：Telegram 机器人配置（连接后由角色写入）====================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=
# TELEGRAM_CENTRAL_GROUP_ID=
# TELEGRAM_DESIGN_GROUP=
# TELEGRAM_ENGINEERING_GROUP=
# TELEGRAM_OPS_GROUP=
# TELEGRAM_RESOURCE_GROUP=
# TELEGRAM_HR_GROUP=

# ==================== 可选：其他 API Key（按需配置）====================
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# SEARCH_API_KEY=
# IMAGE_GEN_API_KEY=
