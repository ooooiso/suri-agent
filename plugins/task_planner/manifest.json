{
  "manifest_version": "1.0",
  "name": "task_planner",
  "version": "1.0.0",
  "entry_point": "plugin.py",
  "min_suri_version": "1.0.0",
  "type": "capability",
  "description": "任务分解引擎，将复杂任务分解为带依赖关系的可执行步骤序列",
  "permissions": ["task.*", "llm.request"],
  "event_subscriptions": ["task.plan_requested", "task.replan_requested", "task_planner.register_rules"],
  "dependencies": ["suri_core", "llm_gateway", "role_manager"],
  "config_schema": {
    "task_planner": {
      "default_planning_mode": { "type": "string", "default": "auto", "enum": ["auto", "rule", "llm"] },
      "llm_model": { "type": "string", "default": "deepseek/deepseek-chat" },
      "max_steps_per_plan": { "type": "integer", "default": 20, "min": 1, "max": 50 },
      "enable_template_matching": { "type": "boolean", "default": true }
    }
  }
}
