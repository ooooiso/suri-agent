{
  "manifest_version": "1.0",
  "name": "log_service",
  "version": "1.0.0",
  "entry_point": "plugin.py",
  "min_suri_version": "1.0.0",
  "type": "service",
  "description": "分级日志、分类归档",
  "author": "",
  "permissions": ["*"],
  "event_subscriptions": ["*"],
  "fs_permissions": {
    "read": ["~/.suri/runtime/logs/"],
    "write": ["~/.suri/runtime/logs/"]
  },
  "runtime_mutable": true,
  "dependencies": ["suri_core"],
  "config_schema": {
    "log_service": {
      "log_base": { "type": "string", "default": "~/.suri/runtime/logs/" },
      "retention_days": { "type": "integer", "default": 30 }
    }
  }
}
