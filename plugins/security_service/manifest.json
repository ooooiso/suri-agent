{
  "manifest_version": "1.0",
  "name": "security_service",
  "version": "1.0.0",
  "entry_point": "plugin.py",
  "min_suri_version": "1.0.0",
  "type": "service",
  "description": "安全沙箱与权限管控",
  "author": "",
  "permissions": ["system.*", "tool.call"],
  "event_subscriptions": ["tool.call", "user.command"],
  "fs_permissions": {
    "read": ["suri-agent/", "~/.suri/"],
    "write": ["~/.suri/"]
  },
  "runtime_mutable": true,
  "dependencies": ["suri_core", "config_service"],
  "config_schema": {
    "security_service": {
      "approval_timeout": { "type": "integer", "default": 300 },
      "enable_sandbox": { "type": "boolean", "default": true }
    }
  }
}
