{
  "manifest_version": "1.0",
  "name": "config_service",
  "version": "1.0.0",
  "entry_point": "plugin.py",
  "min_suri_version": "1.0.0",
  "type": "service",
  "description": "统一配置中心，支持热重载",
  "author": "",
  "permissions": ["system.*"],
  "event_subscriptions": ["system.config_changed", "user.command"],
  "fs_permissions": {
    "read": ["~/.suri/"],
    "write": ["~/.suri/"]
  },
  "runtime_mutable": true,
  "dependencies": ["suri_core"],
  "config_schema": {
    "config_service": {
      "config_path": { "type": "string", "default": "~/.suri/config.json" },
      "auto_reload": { "type": "boolean", "default": true }
    }
  }
}
